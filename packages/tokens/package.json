{
  "name": "@dzip-ui/tokens",
  "type": "module",
  "version": "0.1.0-alpha.0",
  "description": "Design tokens for the dzip-ui component library",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./css": "./dist/tokens.css",
    "./tailwind": {
      "types": "./dist/tailwind-theme.d.ts",
      "import": "./dist/tailwind-theme.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    }
  },
  "license": "MIT",
  "files": [
    "LICENSE",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate": "tsx src/generate.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsx src/generate.ts && vite build"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "vite-plugin-dts": "^4.5.4"
  }
}
