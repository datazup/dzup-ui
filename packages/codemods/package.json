{
  "name": "@dzup-ui/codemods",
  "type": "module",
  "version": "0.0.1",
  "description": "Code transforms for migrating from old dzup-ui to vNext",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "bin": {
    "dzup-codemod": "./bin/dzup-codemod.js"
  },
  "license": "MIT",
  "files": [
    "LICENSE",
    "!src/**/*.spec.ts",
    "!src/**/*.test.ts",
    "!src/**/__tests__",
    "bin",
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "codemod": "node bin/dzup-codemod.js"
  },
  "dependencies": {
    "glob": "^11.0.0",
    "jscodeshift": "^17.0.0"
  },
  "devDependencies": {
    "@types/jscodeshift": "^0.12.0",
    "typescript": "^5.7.0"
  }
}
