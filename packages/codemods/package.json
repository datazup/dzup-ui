{
  "name": "@dzip-ui/codemods",
  "type": "module",
  "version": "0.1.0-alpha.0",
  "description": "Code transforms for migrating from old dzip-ui to vNext",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "dzup-codemod": "./bin/dzup-codemod.js"
  },
  "license": "MIT",
  "files": [
    "LICENSE",
    "bin",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "postbuild": "chmod +x bin/dzup-codemod.js",
    "typecheck": "tsc --noEmit",
    "codemod": "node bin/dzup-codemod.js"
  },
  "dependencies": {
    "glob": "^11.0.0",
    "jscodeshift": "^17.0.0"
  },
  "devDependencies": {
    "@types/jscodeshift": "^0.12.0",
    "typescript": "^5.7.0"
  }
}
