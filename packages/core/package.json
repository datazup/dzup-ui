{
  "name": "@dzip-ui/core",
  "type": "module",
  "version": "0.1.0-alpha.0",
  "description": "Core foundational components for dzip-ui",
  "sideEffects": [
    "*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./resolver": {
      "types": "./dist/resolver.d.ts",
      "import": "./dist/resolver.js"
    },
    "./styles": "./dist/index.css"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "license": "MIT",
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "build": "vite build"
  },
  "peerDependencies": {
    "reka-ui": "^2.0.0",
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@dzip-ui/contracts": "workspace:*",
    "@dzip-ui/tokens": "workspace:*",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.0.0",
    "tailwind-variants": "^0.3.0"
  },
  "devDependencies": {
    "@floating-ui/vue": "^1.1.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "lucide-vue-next": "^0.475.0",
    "reka-ui": "^2.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "vue": "^3.5.13"
  }
}
