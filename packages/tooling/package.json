{
  "name": "@dzup-ui/tooling",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "description": "Validators, boundary checks, and token compliance tools for dzip-ui",
  "scripts": {
    "typecheck": "tsc --noEmit",
