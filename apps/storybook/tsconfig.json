{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@dzup-ui/tokens": ["../../packages/tokens/src"],
      "@dzup-ui/tokens/*": ["../../packages/tokens/*"],
      "@dzup-ui/contracts": ["../../packages/contracts/src"],
      "@dzup-ui/core": ["../../packages/core/src"],
      "@dzup-ui/pro": ["../../packages/pro/src"]
    }
  },
  "include": [
    ".storybook/**/*.ts",
    "stories/**/*.ts",
    "stories/**/*.mdx",
    "../../packages/core/src/**/*.stories.ts",
    "../../packages/pro/src/**/*.stories.ts",
    "../../packages/core/stories/**/*.stories.ts",
    "../../packages/pro/stories/**/*.stories.ts"
  ]
}
